# ============================================================
# Exemple de variables pour Render (backend) + Vercel (frontend)
# Sur Render : Dashboard → Environment → ajoute ces clés
# Ne committe JAMAIS les vraies valeurs secrètes
# ============================================================

DEBUG=False
SECRET_KEY=changez-moi-par-une-cle-secrete-longue-aleatoire

# Hostname Render (sans https://) — ex. regiparc.onrender.com
ALLOWED_HOSTS=regiparc.onrender.com

# URL exacte du frontend Vercel (avec https, sans slash final)
# Temporaire : http://localhost:3000 puis remplace par l'URL Vercel
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# MySQL Aiven
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=votre_mot_de_passe
DB_HOST=votre-host.aivencloud.com
DB_PORT=18923

# Email SMTP (reset mot de passe)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre.email@gmail.com
EMAIL_HOST_PASSWORD=mot-de-passe-application-gmail
DEFAULT_FROM_EMAIL=votre.email@gmail.com
