# Variables à copier dans Render → Environment (PAS dans GitHub)
# Remplace les valeurs exemple par les tiennes

DEBUG=False
SECRET_KEY=une-longue-cle-secrete-aleatoire
PYTHON_VERSION=3.13.2

# Hostname Render (sans https) — ex. regiparc-api.onrender.com
ALLOWED_HOSTS=regiparc-api.onrender.com

# URL Vercel (après déploiement frontend) — https://..., sans slash final
CORS_ALLOWED_ORIGINS=https://ton-projet.vercel.app
CSRF_TRUSTED_ORIGINS=https://ton-projet.vercel.app

# MySQL Aiven
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=TON_MOT_DE_PASSE_AIVEN
DB_HOST=ton-host.aivencloud.com
DB_PORT=18923
DB_SSL=True

# Email (reset mot de passe)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=ton.email@gmail.com
EMAIL_HOST_PASSWORD=mot-de-passe-application-gmail
DEFAULT_FROM_EMAIL=ton.email@gmail.com
